rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthorized() {
      return isSignedIn() && request.auth.token.email_verified == true && (
        request.auth.token.email == 'elkhiraouia@gmail.com' ||
        exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email.lower()))
      );
    }

    function isOwner(userId) {
      return isAuthorized() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validators ---

    function isValidTrade(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.date is string &&
             data.symbol is string &&
             data.pnl is number;
    }

    function isValidTradeReview(userId, data) {
      return data.id is string && data.id.size() <= 128 &&
             data.tradeId is string && data.tradeId.size() <= 128 &&
             exists(/databases/$(database)/documents/users/$(userId)/trades/$(data.tradeId)) &&
             (data.get('mistakes', []).size() <= 20);
    }

    function isValidPremarket(data) {
      return data.id is string && data.date is string &&
             (data.get('checklist', []).size() <= 30);
    }

    // --- Rule Blocks ---

    match /users/{userId} {
      
      // Root user doc for settings/profile
      allow get: if isOwner(userId);
      allow write: if isOwner(userId) && !incoming().keys().hasAny(['isAdmin', 'role']);

      match /trades/{tradeId} {
        allow get, list: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(tradeId) && isValidTrade(incoming());
        allow delete: if isOwner(userId);
      }

      match /tradeReviews/{reviewId} {
        allow get: if isOwner(userId) && isValidId(reviewId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(reviewId) && isValidTradeReview(userId, incoming());
        allow update: if isOwner(userId) && isValidId(reviewId) && isValidTradeReview(userId, incoming());
        allow delete: if isOwner(userId);
      }

      match /premarkets/{pmId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(pmId) && isValidPremarket(incoming());
        allow delete: if isOwner(userId);
      }

      match /reviews/{revId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(revId);
        allow delete: if isOwner(userId);
      }

      match /mistakes/{mistId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(mistId);
        allow delete: if isOwner(userId);
      }

      match /outlooks/{outId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(outId);
        allow delete: if isOwner(userId);
      }

      match /setups/{setupId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(setupId);
        allow delete: if isOwner(userId);
      }
    }

    match /authorized_users/{email} {
      allow get: if isSignedIn() && request.auth.token.email == email;
    }
  }
}
